  "storyCallouts": [
    "The day looked lighter, but felt heavier.",
    "Meeting hours tell you how full the calendar is. Fragmentation tells you how usable the day is.",
    "A 45-minute gap often becomes email cleanup, not deep work.",
    "The goal is not zero meetings. The goal is intentional meetings.",
    "Protecting one long focus block can matter more than removing one short meeting."
  ],
  "recommendedInsights": [
    {
      "title": "Total meeting hours are a blunt metric",
      "body": "Two people can have very different productivity experiences with similar or even inverted meeting loads."
    },
    {
      "title": "Fragmentation creates hidden work",
      "body": "Every switch between meeting mode and production mode creates re-entry cost."
    },
    {
      "title": "Focus blocks are the scarce resource",
      "body": "The most important metric is not just how much time is free, but whether free time is long enough to use."
    }
  ]
}